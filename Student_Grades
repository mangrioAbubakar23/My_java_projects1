public boolean finalGradeInArray(char[] grades, char target) {
    for (int i = 0; i < grades.length; i++) {
        if (grades[i] == target) {
            return true; // found it
        }
    }
    return false; // not found after checking whole array
}

public char[] getGradeArray(int count){
    char[] grade = new char[count];
        for(int i=0; i<count;i++){
        if(i%5==0){
                grade[i]='A';
            }
        else if(i%5==1){
                grade[i]='B';        
            }
        else if(i%5==2){
            grade[i]='C';

        }
        else if(i%5==3){
            grade[i]='D';
        }
        else {
            grade[i]='F';
        }
        

}
  return grade;          
}
