public double calculateRowAverage(int[][] grades, int row ){
    double SumAll=0;

    for(int i=0;i<grades[row].length;i++){
        SumAll+=grades[row][i];

    }
    return SumAll/grades[row].length;
}

public double calculateColumnAverage(int[][] grades,int column){
    double SumAll=0;
    for(int i=0;i<grades.length;i++){
        SumAll+=grades[i][column];
    }
    return SumAll/grades.length;
}







