public double processGPAs(double[] gpas) {
    double highest = 0.0;  // start with smallest valid GPA

    for (double gpa : gpas) {
        if (gpa > 4.0) {      // invalid GPA, stop loop
            break;
        }
        if (gpa < 1.0) {      // skip very low GPA
            continue;
        }
        if (gpa > highest) {  // update highest valid GPA
            highest = gpa;
        }
    }

    return highest;
}

